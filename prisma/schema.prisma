// ReelWrite — TikTok for writers. 7-second reels to market books.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  displayName  String
  bio          String   @default("")
  avatarColor  String   @default("#f59e0b") // gradient seed
  avatarEmoji  String   @default("✍️")
  isWriter     Boolean  @default(true)
  role         String   @default("USER") // USER | ADMIN
  banned       Boolean  @default(false)
  followers    Int      @default(0)
  following    Int      @default(0)
  reelsCount   Int      @default(0)
  createdAt    DateTime @default(now())

  reels        Reel[]
  books        Book[]
  likes        Like[]
  comments     Comment[]
  followsFrom  Follow[] @relation("follower")
  followsTo    Follow[] @relation("followee")
}

model Book {
  id          String   @id @default(cuid())
  authorId    String
  title       String
  subtitle    String   @default("")
  coverColor  String   @default("#111827") // book spine color
  coverAccent String   @default("#fbbf24")
  coverEmoji  String   @default("📖")
  description String   @default("")
  genre       String   @default("Fiction")
  buyLink     String   @default("")
  pages       Int      @default(0)
  createdAt   DateTime @default(now())

  author      User     @relation(fields: [authorId], references: [id])
  reels       Reel[]
}

model Reel {
  id          String   @id @default(cuid())
  authorId    String
  bookId      String?
  caption     String   @default("")
  hook        String   // the 7-second kinetic text — usually a quote or first line
  hookLines   String   @default("") // newline-separated lines for animation
  mood        String   @default("amber") // gradient key: amber, rose, emerald, violet, slate, ocean
  duration    Int      @default(7) // 7 seconds — the brand promise
  videoUrl    String?  // optional uploaded video
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  saves       Int      @default(0)
  views       Int      @default(0)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())

  author      User     @relation(fields: [authorId], references: [id])
  book        Book?    @relation(fields: [bookId], references: [id])
  likeRows    Like[]
  commentRows Comment[]
}

model Like {
  id        String   @id @default(cuid())
  reelId    String
  userId    String
  createdAt DateTime @default(now())

  reel      Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reelId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  reelId    String
  userId    String
  text      String
  createdAt DateTime @default(now())

  reel      Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Follow {
  id          String @id @default(cuid())
  followerId  String
  followeeId  String
  createdAt   DateTime @default(now())

  follower    User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followee    User @relation("followee", fields: [followeeId], references: [id], onDelete: Cascade)

  @@unique([followerId, followeeId])
}
