// ReelWrite — TikTok for writers. 7-second reels to market books.
//
// DATABASE PROVIDER:
// - Local dev (sandbox): SQLite (file-based, no setup needed)
// - Production (Vercel): PostgreSQL (change provider below to "postgresql")
//
// To switch to Postgres for production:
//   1. Change provider from "sqlite" to "postgresql"
//   2. Set DATABASE_URL to your Postgres connection string
//   3. Run: bun run db:push
//   4. Run: bun run scripts/seed.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Change to "postgresql" for production deployment
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  displayName   String
  email         String    @unique
  passwordHash  String?   // null for OAuth-only users
  image         String?
  bio           String    @default("")
  avatarColor   String    @default("#f59e0b") // gradient seed
  avatarEmoji   String    @default("✍️")
  isWriter      Boolean   @default(true)
  role          String    @default("USER") // USER | ADMIN
  banned        Boolean   @default(false)
  isPrivate     Boolean   @default(false) // private accounts hide their reels from non-followers
  followers     Int       @default(0)
  following     Int       @default(0)
  reelsCount    Int       @default(0)
  createdAt     DateTime  @default(now())

  reels         Reel[]
  books         Book[]
  likes         Like[]
  comments      Comment[]
  followsFrom   Follow[]  @relation("follower")
  followsTo     Follow[]  @relation("followee")
  conversations ConversationParticipant[]
  messagesSent  DirectMessage[]
}

model Book {
  id          String   @id @default(cuid())
  authorId    String
  title       String
  subtitle    String   @default("")
  coverColor  String   @default("#111827") // book spine color
  coverAccent String   @default("#fbbf24")
  coverEmoji  String   @default("📖")
  description String   @default("")
  genre       String   @default("Fiction")
  buyLink     String   @default("")
  pages       Int      @default(0)
  createdAt   DateTime @default(now())

  author      User     @relation(fields: [authorId], references: [id])
  reels       Reel[]
}

model Reel {
  id          String   @id @default(cuid())
  authorId    String
  bookId      String?
  caption     String   @default("")
  hook        String   // the 7-second kinetic text — usually a quote or first line
  hookLines   String   @default("") // newline-separated lines for animation
  mood        String   @default("amber") // gradient key: amber, rose, emerald, violet, slate, ocean
  duration    Int      @default(7) // 7 seconds — the brand promise
  videoUrl    String?  // optional uploaded video
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  saves       Int      @default(0)
  views       Int      @default(0)
  featured      Boolean  @default(false)
  background    String   @default("mood") // "mood" (gradient) | "cover" (book cover) | "image" (custom uploaded/URL image)
  backgroundImage String? // base64 data URL or https URL when background === "image"
  archived      Boolean  @default(false) // archived reels are hidden from feed but kept on profile
  createdAt   DateTime @default(now())

  author      User     @relation(fields: [authorId], references: [id])
  book        Book?    @relation(fields: [bookId], references: [id])
  likeRows    Like[]
  commentRows Comment[]
}

model Like {
  id        String   @id @default(cuid())
  reelId    String
  userId    String
  createdAt DateTime @default(now())

  reel      Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reelId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  reelId    String
  userId    String
  text      String
  createdAt DateTime @default(now())

  reel      Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Follow {
  id          String @id @default(cuid())
  followerId  String
  followeeId  String
  createdAt   DateTime @default(now())

  follower    User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followee    User @relation("followee", fields: [followeeId], references: [id], onDelete: Cascade)

  @@unique([followerId, followeeId])
}

// Security monitoring — logs every intrusion attempt and tracks blocked IPs
model SecurityEvent {
  id        String   @id @default(cuid())
  ip        String
  path      String   // the path that was attempted
  method    String   // GET, POST, etc.
  userAgent String   @default("")
  referer   String   @default("")
  type      String   // HONEYPOT | SQL_INJECTION | XSS | PATH_TRAVERSAL | RATE_LIMIT | BLOCKED | SCAN
  severity  String   // LOW | MEDIUM | HIGH | CRITICAL
  blocked   Boolean  @default(false)
  metadata  String   @default("{}") // JSON string for extra context
  createdAt DateTime @default(now())

  @@index([ip])
  @@index([createdAt])
  @@index([type])
}

model BlockedIp {
  id        String   @id @default(cuid())
  ip        String   @unique
  reason    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// DM system — conversations between 2 users
model Conversation {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  participants ConversationParticipant[]
  messages     DirectMessage[]
}

model ConversationParticipant {
  id              String       @id @default(cuid())
  conversationId  String
  userId          String
  lastReadAt      DateTime     @default(now())

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model DirectMessage {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  text           String
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}
